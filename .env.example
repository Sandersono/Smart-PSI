GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Runtime / app
NODE_ENV="development"
PORT="3000"
APP_URL="http://localhost:3000"
ALLOW_DEV_USER_BYPASS="false"
CORS_ALLOWED_ORIGINS="http://localhost:3000"
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX="300"

# Feature flags (keep disabled by default in production)
FEATURE_GOOGLE_ENABLED="false"
FEATURE_ASAAS_ENABLED="false"

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase service role key (server-only, never expose in frontend)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Supabase public values for frontend auth
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Local-only fallback when ALLOW_DEV_USER_BYPASS=true and NODE_ENV!=production
SUPABASE_DEV_USER_ID="00000000-0000-0000-0000-000000000000"

# Google Calendar integration
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"
GOOGLE_WEBHOOK_TOKEN=""

# Asaas integration
ASAAS_API_KEY=""
ASAAS_BASE_URL="https://sandbox.asaas.com/api/v3"
ASAAS_WEBHOOK_TOKEN=""
ASAAS_DEFAULT_SESSION_VALUE="150"

# Encryption secret for Google/Asaas sensitive tokens storage
INTEGRATIONS_ENCRYPTION_KEY=""

# Optional token for internal monthly billing job endpoint
INTERNAL_JOB_TOKEN=""

# Observability
SENTRY_DSN=""
VITE_SENTRY_DSN=""
